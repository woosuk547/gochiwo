// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model CustomerRequest {
  id           String   @id @default(cuid())
  title        String
  description  String
  address      String?
  imageUrl     String?
  latitude     Float?
  longitude    Float?
  status       String   @default("PENDING") // PENDING, MATCHED, COMPLETED
  contractorId String?
  createdAt    DateTime @default(now())
  reviews      Review[]
}

model Contractor {
  id              String   @id @default(cuid())
  name            String
  phone           String
  serviceArea     String
  address         String?  // 전체 도로명 주소
  latitude        Float
  longitude       Float
  rating          Float    @default(4.5)
  reviewCount     Int      @default(0)
  completedJobs   Int      @default(0)
  trustScore      Float    @default(85.0) // 0-100
  responseTime    Int      @default(30) // 평균 응답 시간 (분)
  profileImage    String?  // 프로필 이미지 URL
  description     String?  // 업체 소개
  specialties     String?  // 전문 분야 (JSON array as string)
  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  reviews         Review[]
}

model Review {
  id          String          @id @default(cuid())
  contractorId String
  requestId    String
  customerName String          @default("익명")
  rating       Int             // 1-5
  comment      String
  createdAt    DateTime        @default(now())
  contractor   Contractor      @relation(fields: [contractorId], references: [id])
  request      CustomerRequest @relation(fields: [requestId], references: [id])
}
